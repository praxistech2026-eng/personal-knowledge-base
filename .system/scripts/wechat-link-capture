#!/bin/bash
# wechat-link-capture - 微信收到链接后保存到 Obsidian Inbox
# Usage: wechat-link-capture "<url>" "<来源>" "<备注>"
# 来源如：微信文章/抖音/小红书/bilibili/公众号等

set -euo pipefail

VAULT="$HOME/PersonalKnowledge"
INBOX="$VAULT/Inbox"
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
DATE=$(date '+%Y-%m-%d')
URL="${1:-}"
SOURCE="${2:-微信}"
NOTE="${3:-}"

# Validate URL
if [[ -z "$URL" ]]; then
    echo "Usage: wechat-link-capture <url> [来源] [备注]"
    exit 1
fi

# Create inbox entry
HASH=$(printf '%s' "$URL" | md5sum | cut -c1-8)
FILENAME="$INBOX/${DATE}_${HASH}.md"

cat > "$FILENAME" <<EOF
# 链接收藏

## 🔗 URL
$URL

## 📌 来源
$SOURCE

## 📝 备注
$NOTE

## ⏰ 收藏时间
$TIMESTAMP

## ✅ 处理状态
- [ ] 未处理
EOF

echo "[wechat-link-capture] ✅ 已保存到 Inbox: $FILENAME"
echo "$FILENAME"
