#!/bin/bash
# hermes-poll - Polling-based real-time sync (alternative to inotifywait)
# Adds to crontab for per-minute change detection

CRON_ENTRY="* * * * * $HOME/HermesKnowledge/.system/scripts/hermes-push-auto"

# Check if already installed
if crontab -l 2>/dev/null | grep -q "hermes-push-auto"; then
    echo "[hermes-poll] Already installed in crontab"
    exit 0
fi

# Add to crontab
(crontab -l 2>/dev/null; echo "$CRON_ENTRY") | crontab -

echo "[hermes-poll] Installed: runs hermes-push every minute"
echo "[hermes-poll] Changes are detected via git diff, only committed when files change"
