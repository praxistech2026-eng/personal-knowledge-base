#!/bin/bash
# hermes-push - Manual immediate vault sync
# Usage: hermes-push ["optional commit message"]

set -euo pipefail

VAULT="$HOME/PersonalKnowledge"
MSG="${1:-$(date '+%Y-%m-%d %H:%M:%S')}"

cd "$VAULT"

# 检查是否有变更
if git diff --quiet && git diff --cached --quiet && [ -z "$(git ls-files --others --exclude-standard)" ]; then
    echo "[hermes-push] No changes to sync"
    exit 0
fi

# 添加所有变更
git add -A

# 检查变更内容，排除 AgentSessions（只做静默同步）
CHANGED=$(git diff --cached --name-only | grep -v "^AgentSessions/" | wc -l)
SESSION_CHANGED=$(git diff --cached --name-only | grep "^AgentSessions/" | wc -l)

if [ "$CHANGED" -gt 0 ]; then
    FILES=$(git diff --cached --name-only | grep -v "^AgentSessions/" | tr '\n' ' ')
    git commit -m "[sync] $MSG: $FILES"
    echo "[hermes-push] Committed: $FILES"
fi

if [ "$SESSION_CHANGED" -gt 0 ]; then
    git commit -m "[sync] sessions archive" --no-gpg-sign
    echo "[hermes-push] Committed: $(git diff --cached --name-only | grep "^AgentSessions/" | wc -l) session files"
fi

# Pull rebase then push
git pull --rebase origin main 2>/dev/null || true
git push origin main

echo "[hermes-push] Synced at $(date '+%Y-%m-%d %H:%M:%S')"
