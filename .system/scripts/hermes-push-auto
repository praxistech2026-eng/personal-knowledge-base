#!/bin/bash
# hermes-push-auto: 每分钟检测 PersonalKnowledge 变更，自动 commit + push
# 由 crontab 调度
set -e
cd /home/shin/PersonalKnowledge
git add -A 2>/dev/null
if ! git diff --cached --quiet 2>/dev/null; then
  git commit -m "auto: $(date '+%Y-%m-%d %H:%M:%S') vault sync" >/dev/null 2>&1 || true
  git push origin main 2>/dev/null || echo "[$(date)] push failed (will retry next minute)"
fi
