#!/bin/bash
# hermes-push-auto - Silent auto-sync for cron (no output unless error)
# Called by cron every minute

set +e  # Don't exit on error

VAULT="$HOME/HermesKnowledge"
cd "$VAULT"

# Check for changes
if git diff --quiet && git diff --cached --quiet && [ -z "$(git ls-files --others --exclude-standard)" ]; then
    exit 0  # No changes, silent exit
fi

# Add all changes
git add -A

# Commit with minimal message
git commit -m "sync: $(date '+%Y-%m-%d %H:%M')" --quiet 2>/dev/null

# Push (ignore errors - next run will catch it)
git pull --rebase origin main 2>/dev/null
git push origin main 2>/dev/null
